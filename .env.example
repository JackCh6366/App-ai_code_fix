# GEMINI_API_KEY: Required for Google Gemini AI API calls.
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# NVIDIA_API_KEY: Required for NVIDIA NIM (NVIDIA Code, Nemotron, Meta Llama) API calls.
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"

# APP_URL: The URL where this app is hosted (optional, for self-referential links).
APP_URL="https://your-app.vercel.app"
